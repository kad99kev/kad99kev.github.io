---
layout: none
permalink: /images/manifest.json
---
{
	"name": {
		{ site.title | jsonify
		}
	},
	"short_name": {
		{ site.name | jsonify
		}
	},
	"description": {
		{ site.description | jsonify
		}
	},
	"start_url": "{{ site.baseurl | default: '/' }}",
	"lang": {
		{ site.locale | default: "en" | jsonify
		}
	},
	"icons": [
		{
			"src": "/images/favicon.png",
			"sizes": "192x192",
			"type": "image/png"
		},
		{
			"src": "/images/favicon.png",
			"sizes": "512x512",
			"type": "image/png"
		}
	]
}